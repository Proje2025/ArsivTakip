<Window x:Class="ArsivTakip.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Arşiv Takip Programı" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Window.Resources>
        <Style TargetType="Button" x:Key="MenuButton">
            <Setter Property="Background" Value="#2E5090"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A6CB0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1E4080"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#2E5090"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2E5090" Padding="15,10">
            <Grid>
                <TextBlock Text="Arşiv Takip Programı"
                           FontSize="20" FontWeight="Bold"
                           Foreground="White" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="White" Padding="10" BorderBrush="#DDD" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Button Content="+ Klasör Ekle" Style="{StaticResource MenuButton}" Command="{Binding KlasorEkleCommand}"/>
                <Button Content="+ Evrak Ekle" Style="{StaticResource MenuButton}" Command="{Binding EvrakEkleCommand}"/>
                <Button Content="Evrak Güncelle" Style="{StaticResource MenuButton}" Command="{Binding EvrakGuncelleCommand}"/>
                <Button Content="Evrak Sil" Style="{StaticResource MenuButton}" Command="{Binding EvrakSilCommand}"/>
                <Button Content="Güncelleme" Style="{StaticResource MenuButton}" Background="#4CAF50" Click="GuncellemeKontrol_Click"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="2" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel - Klasör Tree -->
            <Border Grid.Column="0" Background="White" CornerRadius="5" Margin="0,0,5,0" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="KLASÖRLER" FontWeight="Bold" FontSize="14" Foreground="#2E5090" Margin="0,0,0,10"/>

                    <TreeView Grid.Row="1" x:Name="KlasorTreeView"
                              ItemsSource="{Binding KlasorTree}"
                              BorderThickness="0">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <TextBlock Text="{Binding KlasorAdi}" Padding="3" FontSize="13"/>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>

                    <Button Grid.Row="2" Content="Seçili Klasörü Sil"
                            Style="{StaticResource MenuButton}"
                            Background="#C04040"
                            Command="{Binding KlasorSilCommand}"
                            Margin="0,10,0,0"/>
                </Grid>
            </Border>

            <!-- Right Panel - Evrak List -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Arama Panel -->
                <Border Grid.Row="0" Background="White" CornerRadius="5" Padding="15" Margin="5,0,0,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="ARAMA" FontWeight="Bold" FontSize="14" Foreground="#2E5090" Margin="0,0,0,10"/>
                        <WrapPanel Grid.Row="1">
                            <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                                <TextBlock Text="Konu/Açıklama:" VerticalAlignment="Center" Width="120"/>
                                <TextBox Width="180" Padding="5" Text="{Binding AramaMetni, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                                <TextBlock Text="Sayı:" VerticalAlignment="Center" Width="120"/>
                                <TextBox Width="180" Padding="5" Text="{Binding AramaSayi, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                                <TextBlock Text="Başlangıç Tarihi:" VerticalAlignment="Center" Width="120"/>
                                <DatePicker Width="180" SelectedDate="{Binding AramaBaslangicTarih}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                                <TextBlock Text="Bitiş Tarihi:" VerticalAlignment="Center" Width="120"/>
                                <DatePicker Width="180" SelectedDate="{Binding AramaBitisTarih}"/>
                            </StackPanel>
                            <Button Content="Temizle" Style="{StaticResource MenuButton}" Command="{Binding TemizleCommand}" Padding="10,5"/>
                        </WrapPanel>
                    </Grid>
                </Border>

                <!-- Evrak Listesi -->
                <Border Grid.Row="1" Background="White" CornerRadius="5" Margin="5,0,0,0">
                    <DataGrid x:Name="EvrakDataGrid"
                              ItemsSource="{Binding Evraklar}"
                              SelectedItem="{Binding SelectedEvrak}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              RowBackground="White"
                              AlternatingRowBackground="#F8F8F8">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Sayı" Binding="{Binding Sayi}" Width="100"/>
                            <DataGridTextColumn Header="Konu" Binding="{Binding Konu}" Width="*"/>
                            <DataGridTextColumn Header="Tarih" Binding="{Binding Tarih, StringFormat='{}{0:dd.MM.yyyy}'}" Width="100"/>
                            <DataGridTextColumn Header="Klasör" Binding="{Binding Klasor.KlasorAdi}" Width="120"/>
                            <DataGridTextColumn Header="PDF" Width="60">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Var"/>
                                        <Setter Property="Foreground" Value="Green"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PdfDosyaAdi}" Value="{x:Null}">
                                                <Setter Property="Text" Value="Yok"/>
                                                <Setter Property="Foreground" Value="Gray"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding PdfDosyaAdi}" Value="">
                                                <Setter Property="Text" Value="Yok"/>
                                                <Setter Property="Foreground" Value="Gray"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="#E0E0E0" Padding="10,5">
            <TextBlock Text="Hazır" Foreground="#666"/>
        </Border>
    </Grid>
</Window>