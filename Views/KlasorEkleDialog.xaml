<Window x:Class="ArsivTakip.Views.KlasorEkleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Klasör Ekle" MinHeight="350" Width="400"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Yeni Klasör Ekle" FontSize="16" FontWeight="Bold" Foreground="#2E5090" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Klasör Adı:" Margin="0,0,0,5"/>
            <TextBox x:Name="KlasorAdiTextBox" Padding="5" Width="300" HorizontalAlignment="Left"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Klasör Tarihi/Yılı (Opsiyonel):" Margin="0,0,0,5"/>
            <TextBox x:Name="TarihTextBox" Padding="5" Width="300" HorizontalAlignment="Left"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="Üst Klasör (Opsiyonel):" Margin="0,0,0,5"/>
            <ComboBox x:Name="UstKlasorComboBox" Width="300" HorizontalAlignment="Left" DisplayMemberPath="GorunumAdi"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Margin="0,0,0,10">
            <TextBlock Text="Açıklama (Opsiyonel):" Margin="0,0,0,5"/>
            <TextBox x:Name="AciklamaTextBox" Padding="5" Width="300" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>
        </StackPanel>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="İptal" Width="80" Padding="10,5" Margin="0,0,10,0" Click="Iptal_Click"/>
            <Button Content="Kaydet" Width="80" Padding="10,5" Background="#2E5090" Foreground="White" Click="Kaydet_Click"/>
        </StackPanel>
    </Grid>
</Window>