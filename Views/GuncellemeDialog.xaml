<Window x:Class="ArsivTakip.Views.GuncellemeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Yeni Güncelleme" Height="300" Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="🔔" FontSize="28" Margin="0,0,10,0"/>
            <TextBlock Text="Yeni Güncelleme Mevcut!" FontSize="18" FontWeight="Bold" Foreground="#2E5090" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Mevcut Versiyon:" FontWeight="SemiBold"/>
            <TextBlock x:Name="MevcutVersiyonText" Text="1.0.0" Foreground="Gray"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Yeni Versiyon:" FontWeight="SemiBold"/>
            <TextBlock x:Name="YeniVersiyonText" Text="1.0.1" Foreground="Green" FontWeight="Bold"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="Değişiklikler:" FontWeight="SemiBold"/>
            <TextBlock x:Name="DegisikliklerText" TextWrapping="Wrap" MaxHeight="80" Foreground="#555"/>
        </StackPanel>

        <ProgressBar x:Name="IndirmeBar" Grid.Row="4" Visibility="Collapsed" Height="20" Margin="0,10,0,0"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="SonraButton" Content="Sonra" Width="80" Padding="10,5" Margin="0,0,10,0" Click="Sonra_Click"/>
            <Button x:Name="GuncelleButton" Content="Güncelle" Width="100" Padding="10,5" Background="#2E5090" Foreground="White" Click="Guncelle_Click"/>
        </StackPanel>
    </Grid>
</Window>