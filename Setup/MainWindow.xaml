<Window x:Class="ArsivTakip.Setup.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Arşiv Takip Kurulum" Height="220" Width="480"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Arşiv Takip Programı" FontSize="20" FontWeight="Bold" Foreground="#2E5090"/>
        <TextBlock x:Name="StatusText" Grid.Row="1" Margin="0,12,0,8" TextWrapping="Wrap"
                   Text="Son sürüm kontrol ediliyor..."/>
        <ProgressBar x:Name="ProgressBar" Grid.Row="2" Height="22" Minimum="0" Maximum="100" Value="0"/>
        <TextBlock x:Name="VersionText" Grid.Row="3" Margin="0,10,0,0" Foreground="#666" FontSize="12"/>
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="CancelButton" Content="İptal" Width="90" Padding="8,4" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button x:Name="InstallButton" Content="Kur" Width="90" Padding="8,4" IsEnabled="False" Click="Install_Click"/>
        </StackPanel>
    </Grid>
</Window>
